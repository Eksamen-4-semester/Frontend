                            <rect x="10" y="12" width="1" height="1" fill="#1a1a1a"/>
                            <rect x="13" y="12" width="3" height="1" fill="#1a1a1a"/>
                            <rect x="18" y="12" width="3" height="1" fill="#1a1a1a"/>
                            <rect x="8" y="14" width="1" height="1" fill="#1a1a1a"/>
                            <rect x="10" y="14" width="2" height="1" fill="#1a1a1a"/>
                            <rect x="14" y="14" width="1" height="1" fill="#1a1a1a"/>
                            <rect x="16" y="14" width="2" height="1" fill="#1a1a1a"/>
                            <rect x="8" y="16" width="3" height="1" fill="#1a1a1a"/>
                            <rect x="12" y="16" width="1" height="1" fill="#1a1a1a"/>
                            <rect x="15" y="16" width="1" height="1" fill="#1a1a1a"/>
                            <rect x="18" y="16" width="3" height="1" fill="#1a1a1a"/>
                            <rect x="8" y="18" width="1" height="1" fill="#1a1a1a"/>
                            <rect x="10" y="18" width="2" height="1" fill="#1a1a1a"/>
                            <rect x="14" y="18" width="2" height="1" fill="#1a1a1a"/>
                            <rect x="17" y="18" width="4" height="1" fill="#1a1a1a"/>
                        </svg>
                    </div>
                    <div class="pp-qr-sub">Scan for at tjekke ind i centeret</div>
                </div>

            </div>
        </div>
    </div>
}

@code {
    public class StatItem   { public string Value { get; set; } = ""; public string Label { get; set; } = ""; }
    public class InfoItem   { public string Key { get; set; } = ""; public string Value { get; set; } = ""; public bool IsActive { get; set; } }
    public class FitnessItem { public string Key { get; set; } = ""; public string Value { get; set; } = ""; public List<string> Tags { get; set; } = new(); }

    public Member? member;
    public Subscription? Subscription;
    public MemberSubscription? MemberSubscription;

    bool isLoaded = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;
        
        var jwt = await LocalStorage.GetItemAsync<string>("jwt");
        if (string.IsNullOrWhiteSpace(jwt))
        {
            await UserService.Logout();
            Nav.NavigateTo("/");
            return;
        }
        member = await UserService.GetMemberByJwt(jwt);
        if (member == null)
        {
            await UserService.Logout();
            Nav.NavigateTo("/");
            return;
        }

        infoItems = new()
        {
            new() { Key = "Navn", Value = member.FullName },
            new() { Key = "Brugernavn", Value = member.Username },
            new() { Key = "Telefon", Value = "45617546" },
            new() { Key = "Fødselsdato", Value = member.DOB.ToString("dd/MM/yyyy") },
            new() { Key = "Medlemskab", Value = "" },
            new() { Key = "Status", Value = member.Active.ToString()}
        };
        
        var subscriptionDto = await MembershipService.GetMemberSubscriptionById(member.MemberId, jwt);
        if (subscriptionDto != null)
        {
            Subscription = subscriptionDto.Subscription;
            MemberSubscription = subscriptionDto.MemberSubscription;
            infoItems[4].Value = Subscription.Name;
        }
        else
        {
            infoItems[4].Value = "None";
        }

        
        isLoaded = true;
        StateHasChanged();
    }

    private List<StatItem> stats = new()
    {
        new() { Value = "142",  Label = "Besøg i alt" },
        new() { Value = "38",   Label = "Hold booket" },
        new() { Value = "3 år", Label = "Medlem" },
    };

    private List<InfoItem> infoItems = new()
    {
        new() { Key = "Navn",          Value = "Maya Hansen" },
        new() { Key = "E-mail",        Value = "maya.hansen@gmail.com" },
        new() { Key = "Telefon",       Value = "+45 28 34 12 56" },
        new() { Key = "Fødselsdato",   Value = "12. juli 1994" },
        new() { Key = "Medlemskab",    Value = "Ubegrænset — 350 kr/md" },
        new() { Key = "Status",        Value = "Aktiv", IsActive = true },
    };

    private List<FitnessItem> fitnessItems = new()
    {
        new() { Key = "Mål",                    Value = "Vægttab & kondition" },
        new() { Key = "Niveau",                 Value = "Mellemniveau" },
        new() { Key = "Foretrukne aktiviteter", Tags = new() { "HIIT", "Yoga", "Styrke" } },
    };
}