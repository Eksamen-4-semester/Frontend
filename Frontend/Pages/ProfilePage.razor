@page "/ProfilePage"
@using Frontend.Models.Membership
@using Frontend.Models.User
@using Frontend.Services
@inject UserService UserService
@inject MembershipService MembershipService
@inject ILocalStorageService LocalStorage
@inject NavigationManager Nav
@rendermode InteractiveServer

@if (isLoaded)
{
    <div class="pp-wrap">

        <!-- Hero -->
        <div class="pp-hero">
            <div class="pp-hero-left">
                <div class="pp-avatar">MH</div>
                <div>
                    <div class="pp-name">@member.FullName</div>
                    <span class="pp-badge">
                        <i class="bi bi-star-fill" aria-hidden="true"></i>
                        Premium Medlem
                    </span>
                </div>
            </div>
            <div class="pp-hero-right">
                <div class="pp-meta">Medlem siden <span>@member.SignUpDate</span></div>
                <div class="pp-meta">Center <span>Aarhus — Nordre</span></div>
                <div class="pp-meta">Næste betaling <span>1. juni 2026</span></div>
            </div>
        </div>

        <!-- Stats -->
        <div class="pp-stats">
            @foreach (var stat in stats)
            {
                <div class="pp-stat-card">
                    <div class="pp-stat-num">@stat.Value</div>
                    <div class="pp-stat-lbl">@stat.Label</div>
                </div>
            }
        </div>

        <!-- Grid -->
        <div class="pp-grid">

            <!-- Mine oplysninger -->
            <div class="pcard">
                <div class="pcard-top">
                    <div class="pcard-title">Mine oplysninger</div>
                    <button class="pp-edit-btn">
                        <i class="bi bi-pencil" aria-hidden="true"></i> Rediger
                    </button>
                </div>
                @foreach (var info in infoItems)
                {
                    <div class="pp-info-row">
                        <span class="pp-info-key">@info.Key</span>
                        <span class="pp-info-val @(info.IsActive ? "active" : "")">@info.Value</span>
                    </div>
                }
            </div>

            <!-- Højre kolonne -->
            <div class="pp-right-col">

                <!-- Fitnessprofil -->
                <div class="pcard">
                    <div class="pcard-top">
                        <div class="pcard-title">Fitnessprofil</div>
                        <button class="pp-edit-btn">
                            <i class="bi bi-pencil" aria-hidden="true"></i> Rediger
                        </button>
                    </div>
                    @foreach (var item in fitnessItems)
                    {
                        <div class="pp-fitness-row">
                            <div class="pp-fitness-key">@item.Key</div>
                            @if (item.Tags.Any())
                            {
                                <div class="pp-tags">
                                    @foreach (var tag in item.Tags)
                                    {
                                        <span class="pp-tag">@tag</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="pp-fitness-val">@item.Value</div>
                            }
                        </div>
                    }
                </div>

                <!-- QR Kode -->
                <div class="pcard pp-qr-card">
                    <div class="pcard-title" style="margin-bottom:1rem;">Din QR-kode</div>
                    <div class="pp-qr-frame">
                        <svg viewBox="0 0 21 21" xmlns="http://www.w3.org/2000/svg" shape-rendering="crispEdges"
                             style="width:100%;height:100%;">
                            <rect width="21" height="21" fill="white"/>
                            <rect x="0" y="0" width="7" height="7" fill="#1a1a1a"/>
                            <rect x="1" y="1" width="5" height="5" fill="white"/>
                            <rect x="2" y="2" width="3" height="3" fill="#1a1a1a"/>
                            <rect x="14" y="0" width="7" height="7" fill="#1a1a1a"/>
                            <rect x="15" y="1" width="5" height="5" fill="white"/>
                            <rect x="16" y="2" width="3" height="3" fill="#1a1a1a"/>
                            <rect x="0" y="14" width="7" height="7" fill="#1a1a1a"/>
                            <rect x="1" y="15" width="5" height="5" fill="white"/>
                            <rect x="2" y="16" width="3" height="3" fill="#1a1a1a"/>
                            <rect x="8" y="0" width="1" height="1" fill="#1a1a1a"/>
                            <rect x="10" y="0" width="1" height="1" fill="#1a1a1a"/>
                            <rect x="12" y="0" width="1" height="1" fill="#1a1a1a"/>
                            <rect x="8" y="2" width="2" height="1" fill="#1a1a1a"/>
                            <rect x="11" y="2" width="2" height="1" fill="#1a1a1a"/>
                            <rect x="8" y="4" width="1" height="1" fill="#1a1a1a"/>
                            <rect x="10" y="4" width="3" height="1" fill="#1a1a1a"/>
                            <rect x="8" y="6" width="1" height="2" fill="#1a1a1a"/>
                            <rect x="10" y="6" width="1" height="1" fill="#1a1a1a"/>
                            <rect x="12" y="6" width="1" height="1" fill="#1a1a1a"/>
                            <rect x="0" y="8" width="3" height="1" fill="#1a1a1a"/>
                            <rect x="4" y="8" width="2" height="1" fill="#1a1a1a"/>
                            <rect x="7" y="8" width="3" height="1" fill="#1a1a1a"/>
                            <rect x="11" y="8" width="2" height="1" fill="#1a1a1a"/>
                            <rect x="14" y="8" width="3" height="1" fill="#1a1a1a"/>
                            <rect x="18" y="8" width="3" height="1" fill="#1a1a1a"/>
