@page "/ProfilePage"
@using Frontend.Models.User
@using Frontend.Services
@inject UserService UserService
@inject ILocalStorageService LocalStorage
@inject NavigationManager Nav
@rendermode InteractiveServer

@if (isLoaded && member != null)
{
    <div class="pp-wrap">
        <ProfileHero Member="member" />
        <ProfileStats Stats="stats" />

        <div class="pp-grid">
            <ProfileInfo InfoItems="infoItems" />

            <div class="pp-right-col">

                <!-- Fitnessprofil -->
                <div class="pcard">
                    <div class="pcard-top">
                        <div class="pcard-title">Fitnessprofil</div>
                        <button class="pp-edit-btn">
                            <i class="bi bi-pencil" aria-hidden="true"></i> Rediger
                        </button>
                    </div>
                    @foreach (var item in fitnessItems)
                    {
                        <div class="pp-fitness-row">
                            <div class="pp-fitness-key">@item.Key</div>
                            @if (item.Tags.Any())
                            {
                                <div class="pp-tags">
                                    @foreach (var tag in item.Tags)
                                    {
                                        <span class="pp-tag">@tag</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="pp-fitness-val">@item.Value</div>
                            }
                        </div>
                    }
                </div>

                <ProfileQR />

            </div>
        </div>
    </div>
}
else if (!isLoaded)
{
    <div class="d-flex justify-content-center mt-5">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}

@code {
    public class FitnessItem { public string Key { get; set; } = ""; public string Value { get; set; } = ""; public List<string> Tags { get; set; } = new(); }

    private Member? member;
    private bool isLoaded = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var jwt = await LocalStorage.GetItemAsync<string>("jwt");
        if (string.IsNullOrWhiteSpace(jwt))
        {
            Nav.NavigateTo("/");
            return;
        }

        member = await UserService.GetMemberByJwt(jwt);
        if (member == null)
        {
            Nav.NavigateTo("/");
            return;
        }

        infoItems = new()
        {
            new() { Key = "Navn",        Value = member.FullName },
            new() { Key = "Brugernavn",  Value = member.Username },
            new() { Key = "Telefon",     Value = "" },
            new() { Key = "Fødselsdato", Value = member.DOB.ToString("dd/MM/yyyy") },
            new() { Key = "Medlemskab",  Value = "" },
            new() { Key = "Status",      Value = member.Active ? "Aktiv" : "Inaktiv", IsActive = member.Active }
        };

        isLoaded = true;
        await InvokeAsync(StateHasChanged);
    }

    private List<ProfileStats.StatItem> stats = new()
    {
        new() { Value = "142",  Label = "Besøg i alt" },
        new() { Value = "38",   Label = "Hold booket" },
        new() { Value = "3 år", Label = "Medlem" },
    };

    private List<ProfileInfo.InfoItem> infoItems = new();

    private List<FitnessItem> fitnessItems = new()
    {
        new() { Key = "Mål",                    Value = "Vægttab & kondition" },
        new() { Key = "Niveau",                 Value = "Mellemniveau" },
        new() { Key = "Foretrukne aktiviteter", Tags = new() { "HIIT", "Yoga", "Styrke" } },
    };
}