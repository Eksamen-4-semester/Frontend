@page "/WearablePage"
@using System.Globalization
@using Microsoft.AspNetCore.Components

<div class="wp-wrap">

    <!-- Hero -->
    <div class="wp-hero">
        <div class="bubbles">
            <div class="bubble"></div>
            <div class="bubble"></div>
            <div class="bubble"></div>
            <div class="bubble"></div>
            <div class="bubble"></div>
            <div class="bubble"></div>
        </div>
        <div class="wp-hero-tag">
            <i class="bi bi-smartwatch"></i> Wearables & Data
        </div>
        <h1 class="wp-hero-title">Din aktivitetsdata</h1>
        <p class="wp-hero-sub">Her er et hurtigt overblik over din træning og dine vigtigste fremskridt.</p>
    </div>

    <!-- Aktivitet -->
    <p class="wp-section-title">Ugentlig aktivitet</p>
    <div class="wp-activity-row">

        <!-- Bar chart -->
        <div class="wp-card">
            <div class="wp-card-title">Aktivitet — denne uge</div>
            <div class="wp-card-sub">Minutter</div>
            <div class="wp-bar-chart">
                @foreach (var bar in barData)
                {
                    <div class="wp-bar @(bar.Active ? "active" : "")" style="height:@(bar.Height)%"></div>
                }
            </div>
            <div class="wp-bar-labels">
                <span>Man</span><span>Tir</span><span>Ons</span><span>Tor</span>
                <span>Fre</span><span>Lør</span><span>Søn</span>
            </div>
            <div class="wp-stats-row">
                <div><div class="wp-stat-val">48.220</div><div class="wp-stat-label">Skridt</div></div>
                <div><div class="wp-stat-val">5.840</div><div class="wp-stat-label">Kcal</div></div>
                <div><div class="wp-stat-val">32,4</div><div class="wp-stat-label">km</div></div>
            </div>
        </div>

        <!-- Line chart -->
        <div class="wp-card">
            <div class="wp-chart-header">
                <div class="wp-card-title">@Active.Label</div>
                <div class="wp-chart-val-row">
                    <span class="wp-chart-val">@Active.Value</span>
                    <span class="wp-chart-unit">@Active.Unit</span>
                    <span class="wp-chart-trend @Active.TrendClass">@Active.Trend</span>
                </div>
            </div>

            <div class="wp-data-tabs">
                @foreach (var ds in Datasets)
                {
                    <div class="wp-data-tab @(ds.Key == activeKey ? "active" : "")"
                         @onclick="() => activeKey = ds.Key">
                        @ds.Value.Label
                    </div>
                }
            </div>

            <div class="wp-line-chart">
                <svg viewBox="0 0 260 140"
                     xmlns="http://www.w3.org/2000/svg"
                     style="width:100%; max-height: 220px; display:block;overflow:visible;">
                    <defs>
                        <linearGradient id="wpGrad" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%" stop-color="@Active.Color" stop-opacity="0.2" />
                            <stop offset="100%" stop-color="@Active.Color" stop-opacity="0" />
                        </linearGradient>
                    </defs>

                    <!-- Gridlinjer -->
                    @for (int g = 0; g <= 4; g++)
                    {
                        var gy = (g / 4.0 * 100 + 10).ToString("F1", CultureInfo.InvariantCulture);
                        <line x1="0" y1="@gy" x2="260" y2="@gy"
                              stroke="rgba(0,0,0,0.06)" stroke-width="0.5" />
                    }

                    <!-- Område -->
                    <path d="@GetAreaPath(Active.Points)" fill="url(#wpGrad)" />

                    <!-- Kurve -->
                    <path d="@GetLinePath(Active.Points)" fill="none"
                          stroke="@Active.Color" stroke-width="2"
                          stroke-linecap="round" stroke-linejoin="round" />

                    <!-- Datapunkter + labels -->
                    @{
                        var ci = CultureInfo.InvariantCulture;
                        var coords = GetCoords(Active.Points);
                        for (int i = 0; i < coords.Count; i++)
                        {
                            var px    = coords[i].X.ToString("F1", ci);
                            var py    = coords[i].Y.ToString("F1", ci);
                            var val   = Active.Points[i].ToString("F1", ci);
                            var isLast = i == coords.Count - 1;

                            <circle cx="@px" cy="@py"
                                    r="@(isLast ? "4" : "3")"
                                    fill="@(isLast ? Active.Color : "white")"
                                    stroke="@Active.Color" stroke-width="1.5" />

                            if (i % 2 == 0 || isLast)
                            {
                                var labelY = (coords[i].Y - 8).ToString("F1", ci);
                                var textTag = $"<text x=\"{px}\" y=\"{labelY}\" text-anchor=\"middle\" font-size=\"7\" fill=\"{Active.Color}\" font-family=\"sans-serif\">{val}</text>";
                                @((MarkupString)textTag)
                            }
                        }
                    }
                </svg>
            </div>
        </div>

    </div>

    <!-- Enheder -->
    <div class="wp-devices-card">
        <p class="wp-section-title" style="margin-bottom:0">Tilslut flere enheder</p>
        <div class="wp-devices-grid">
            @foreach (var device in Devices)
            {
                <div class="wp-device-card">
                    <div class="wp-device-icon">
                        <i class="bi @device.Icon"
                           style="@(device.IconColor != null ? $"color:{device.IconColor}" : "")"></i>
                        @if (device.Connected)
                        {
                            <span class="wp-device-dot"></span>
                        }
                    </div>
                    <div class="wp-device-name">@device.Name</div>
                    <div class="wp-device-status">@device.Status</div>
                    @if (device.Connected)
                    {
                        <button class="wp-btn-connected">Tilsluttet</button>
                    }
                    else
                    {
                        <button class="wp-btn-add">Tilføj</button>
                    }
                </div>
            }
        </div>
    </div>

</div>

@code {
    private string activeKey = "weight";
    private ChartDataset Active => Datasets[activeKey];

    private record SvgPoint(double X, double Y);

    private List<SvgPoint> GetCoords(double[] pts)
    {
        const double W = 260, H = 140;
        const double padding = 20;
        var max = pts.Max();
        var min = pts.Min();
        var range = max - min == 0 ? 1 : max - min;

        return pts.Select((v, i) => new SvgPoint(
            (i / (double)(pts.Length - 1)) * W,
            H - padding - ((v - min) / range * (H - 2 * padding))
        )).ToList();
    }

    private string GetLinePath(double[] pts)
    {
        var coords = GetCoords(pts);
        var sb = new System.Text.StringBuilder();
        var ci = CultureInfo.InvariantCulture;
        sb.Append($"M{coords[0].X.ToString("F1", ci)},{coords[0].Y.ToString("F1", ci)}");
        for (int i = 1; i < coords.Count; i++)
        {
            var (cx, cy) = (coords[i].X, coords[i].Y);
            sb.Append($" L{cx.ToString("F1", ci)},{cy.ToString("F1", ci)}");
        }
        return sb.ToString();
    }

    private string GetAreaPath(double[] pts)
    {
        const double H = 140;
        var coords = GetCoords(pts);
        var line = GetLinePath(pts);
        var last = coords.Last();
        var ci = CultureInfo.InvariantCulture;
        return $"{line} L{last.X.ToString("F1", ci)},{H.ToString(ci)} L0,{H.ToString(ci)} Z";
    }

    private SvgPoint GetLastPoint(double[] pts) => GetCoords(pts).Last();

    public class ChartDataset
    {
        public string Label { get; set; } = "";
        public string Unit { get; set; } = "";
        public string Value { get; set; } = "";
        public string Trend { get; set; } = "";
        public string TrendClass { get; set; } = "";
        public double[] Points { get; set; } = Array.Empty<double>();
        public string Color { get; set; } = "";
    }

    public class BarItem { public int Height { get; set; } public bool Active { get; set; } }
    public class Device  { public string Name { get; set; } = ""; public string Status { get; set; } = ""; public string Icon { get; set; } = ""; public string? IconColor { get; set; } public bool Connected { get; set; } }

    private List<BarItem> barData = new()
    {
        new() { Height = 45 }, new() { Height = 60 }, new() { Height = 35 },
        new() { Height = 80, Active = true }, new() { Height = 55 },
        new() { Height = 70 }, new() { Height = 40 },
    };

    private Dictionary<string, ChartDataset> Datasets = new()
    {
        ["weight"] = new() { Label = "Kropsvægt",     Unit = "kg", Value = "85,0", Trend = "▼ 3,0 siden sidste uge",  TrendClass = "trend-down", Color = "#c03010", Points = new double[] { 85, 86, 84, 88, 87, 89, 90, 88, 87, 86, 88, 85 } },
        ["fat"]    = new() { Label = "Fedtprocent",   Unit = "%",  Value = "18,2", Trend = "▼ 0,3% siden sidste uge", TrendClass = "trend-down", Color = "#ba7517", Points = new double[] { 18, 19, 18.5, 19.5, 19, 20, 19.8, 19.5, 19.2, 18.8, 18.5, 18.2 } },
        ["muscle"] = new() { Label = "Muskelprocent", Unit = "%",  Value = "42,7", Trend = "▲ 0,1% siden sidste uge", TrendClass = "trend-up",   Color = "#1d9e75", Points = new double[] { 42, 41, 41.5, 41, 42, 42.5, 42.3, 42.7, 42.8, 42.5, 42.6, 42.7 } },
        ["water"]  = new() { Label = "Vandprocent",   Unit = "%",  Value = "58,3", Trend = "▲ 0,2% siden sidste uge", TrendClass = "trend-up",   Color = "#185fa5", Points = new double[] { 58, 57, 58.5, 59, 58.5, 58, 57.5, 58, 58.2, 58.3, 58.1, 58.3 } },
        ["bmi"]    = new() { Label = "BMI",           Unit = "",   Value = "23,8", Trend = "▼ 0,1 siden sidste uge",  TrendClass = "trend-down", Color = "#534ab7", Points = new double[] { 24, 24.2, 23.8, 24.5, 24.3, 24.8, 25, 24.6, 24.3, 24, 23.9, 23.8 } },
    };

    private List<Device> Devices = new()
    {
        new() { Name = "Apple Watch", Status = "Series 9",        Icon = "bi-smartwatch",     Connected = true  },
        new() { Name = "Garmin",      Status = "Forerunner 265",  Icon = "bi-smartwatch",     Connected = false },
        new() { Name = "Strava",      Status = "App integration", Icon = "bi-lightning-fill", IconColor = "#e07020", Connected = false },
        new() { Name = "Polar",       Status = "H10 Sensor",      Icon = "bi-heart-pulse",    IconColor = "#e03030", Connected = false },
        new() { Name = "Google Fit",  Status = "App integration", Icon = "bi-phone-fill",     Connected = false },
        new() { Name = "Fitbit",      Status = "Charge 6",        Icon = "bi-activity",       IconColor = "#0070c0", Connected = false },
    };
}