@page "/BuyMembership"
@using Frontend.Models.Membership
@using Frontend.Models.User
@using Frontend.Services
@inject NavigationManager NavMan
@inject ILocalStorageService LocalStorage
@inject UserService UserService
@inject MembershipService MembershipService
@rendermode InteractiveServer

<div class="membership-page">
    <section class="hero">
        <div class="hero-content">
            <span class="eyebrow">Memberships</span>
            <h1>Choose your subscription</h1>
            <p>
                Pick the plan that works best for you. You can add extra features
                and upgrades below.
            </p>
        </div>
    </section>

    @if (!loaded)
    {
        <div class="loading-card">
            <div class="spinner"></div>
            <p>Loading memberships...</p>
        </div>
    }
    else
    {
        @if (subscriptions != null)
        {
            <section class="plans-section">
                <div class="section-heading">
                    <h2>Subscriptions</h2>
                    <p>Select one of our available membership plans.</p>
                </div>

                <div class="plans-grid">
                    @foreach (var sub in subscriptions)
                    {
                        <article class="plan-card">
                            <div class="plan-header">
                                <h3>@sub.Name</h3>
                                <div class="price">
                                    <span>@sub.Price</span>
                                </div>
                            </div>

                            <p class="description">
                                @sub.Description
                            </p>

                            <button class="primary-button" type="button">
                                Choose Plan
                            </button>
                        </article>
                    }
                </div>
            </section>

            @if (AddOns != null && AddOns.Any())
            {
                <section class="addons-section">
                    <div class="section-heading">
                        <h2>Add-ons</h2>
                        <p>Enhance your membership with optional extras.</p>
                    </div>

                    <div class="addons-grid">
                        @foreach (var addOn in AddOns)
                        {
                            <article class="addon-card">
                                <div>
                                    <h3>@addOn.Name</h3>
                                    <p>@addOn.Description</p>
                                </div>

                                <div class="addon-footer">
                                    <strong>@addOn.Price</strong>
                                    <button class="secondary-button" type="button">
                                        Add
                                    </button>
                                </div>
                            </article>
                        }
                    </div>
                </section>
            }
        }
        else
        {
            <div class="error-card">
                <h2>No subscriptions available</h2>
                <p>An error occurred. Please try again later.</p>
            </div>
        }
    }
</div>

@code {

    bool loaded = false;
    Member? member;
    List<Subscription>? subscriptions;
    List<AddOn>? AddOns;
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;
        
        var jwt = await LocalStorage.GetItemAsync<string>("jwt");
        if (string.IsNullOrWhiteSpace(jwt))
        {
            await UserService.Logout();
            NavMan.NavigateTo("/");
            return;
        }
        member = await UserService.GetMemberByJwt(jwt);
        if (member == null)
        {
            await UserService.Logout();
            NavMan.NavigateTo("/");
            return;
        }

        var subs = await MembershipService.GetAllSubscriptions();
        var addOns = await MembershipService.GetAllAddOns();
        
        subscriptions = subs;
        AddOns = addOns;
        loaded = true;
        StateHasChanged();
    }

}