@page "/BuyMembership"
@using Frontend.Models.Membership
@using Frontend.Models.User
@using Frontend.Services
@inject NavigationManager NavMan
@inject ILocalStorageService LocalStorage
@inject UserService UserService
@inject MembershipService MembershipService
@rendermode InteractiveServer

<div class="membership-page">
    <section class="hero">
        <div class="hero-content">
            <span class="eyebrow">Medlemsskaber</span>
            <h1>Vælg DIT medlemsskab</h1>
            <p>
                Vælg det medlemsskab som virker bedst for dig. Du kan tilføje ekstra ting
                og upgraderinger nedenunder.
            </p>
        </div>
    </section>

    @if (!loaded)
    {
        <div class="loading-card">
            <div class="spinner"></div>
            <p>Loading memberships...</p>
        </div>
    }
    else
    {
        @if (subscriptions != null)
        {
            <section class="plans-section">
                <div class="section-heading">
                    <h2>Medlemsskaber</h2>
                    <p>Vælg en af vores tilgængelige medlemsskaber.</p>
                </div>

                <div class="plans-grid">
                    @foreach (var sub in subscriptions)
                    {
                        <article class="@(hasSubscription ? currentSubscription.SubscriptionId == sub.SubscriptionId ? "plan-card-disabled" : "plan-card" : "plan-card")">
                            <div class="plan-header">
                                <h3>@sub.Name</h3>
                                <div class="price">
                                    <span>@sub.Price kr./md</span>
                                </div>
                            </div>

                            <p class="description">
                                @sub.Description
                            </p>

                            @if (hasSubscription && currentSubscription.SubscriptionId == sub.SubscriptionId)
                            {
                                <button class="primary-button-disabled" type="button" disabled="disabled">
                                    Nuværende plan
                                </button>
                            }
                            else
                            {
                                <button class="primary-button" type="button">
                                    Vælg Plan
                                </button>
                            }
                        </article>
                    }
                </div>
            </section>

            @if (AddOns != null && AddOns.Any())
            {
                <section class="addons-section">
                    <div class="section-heading">
                        <h2>Ekstra</h2>
                        <p>Enhance your membership with optional extras.</p>
                    </div>

                    <div class="addons-grid">
                        @foreach (var addOn in AddOns)
                        {
                            <article class="addon-card">
                                <div>
                                    <h3>@addOn.Name</h3>
                                    <p>@addOn.Description</p>
                                </div>

                                <div class="addon-footer">
                                    <strong>@addOn.Price kr./md</strong>
                                    @if (hasAddOns && memberAddOnIds.Contains(addOn.AddOnId))
                                    {
                                        <button class="secondary-button-disabled" type="button" disabled="disabled">
                                            Købt
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="secondary-button" type="button">
                                            Tilføj
                                        </button>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                </section>
            }
        }
        else
        {
            <div class="error-card">
                <h2>No subscriptions available</h2>
                <p>An error occurred. Please try again later.</p>
            </div>
        }
    }
</div>

@code {

    bool loaded = false;
    bool hasSubscription = false;
    bool hasAddOns = false;
    Member? member;
    List<Subscription>? subscriptions;
    List<AddOn>? AddOns;
    
    MemberSubscription? currentMemberSubscription;
    Subscription? currentSubscription;
    MemberAddOns? memberAddOns;
    List<int> memberAddOnIds;
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;
        
        var jwt = await LocalStorage.GetItemAsync<string>("jwt");
        if (string.IsNullOrWhiteSpace(jwt))
        {
            await UserService.Logout();
            NavMan.NavigateTo("/");
            return;
        }
        member = await UserService.GetMemberByJwt(jwt);
        if (member == null)
        {
            await UserService.Logout();
            NavMan.NavigateTo("/");
            return;
        }

        var membershipDto = await MembershipService.GetMemberSubscriptionById(member.MemberId, jwt);
        if (membershipDto is not null)
        {
            currentMemberSubscription = membershipDto.MemberSubscription;
            currentSubscription = membershipDto.Subscription;
            hasSubscription = true;

            memberAddOns = await MembershipService.GetMemberSubscriptionAddOnsByMemberSubscriptionId(currentMemberSubscription.MemberSubscriptionId, jwt);
            if (memberAddOns is not null)
            {
                memberAddOnIds = memberAddOns.AddOnIds;
                hasAddOns = true;
            }
        }

        var subs = await MembershipService.GetAllSubscriptions();
        var addOns = await MembershipService.GetAllAddOns();
        
        subscriptions = subs;
        AddOns = addOns;
        loaded = true;
        StateHasChanged();
    }

}