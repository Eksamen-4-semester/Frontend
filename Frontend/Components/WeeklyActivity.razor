@using BlazorBootstrap
@using Frontend.Models.Analytics
@using Frontend.Services

<BarChart @ref="_barChart" Height="200" />

@code {
    [Parameter] public List<WeeklySessionDto> Last7Days { get; set; } = new();

    private BarChart _barChart = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await RenderChartAsync();
    }

    private async Task RenderChartAsync()
    {
        var labels = Last7Days.Any()
            ? Last7Days.Select(d => d.Day).ToList()
            : new List<string> { "Man", "Tir", "Ons", "Tor", "Fre", "Lør", "Søn" };

        var data = Last7Days.Any()
            ? Last7Days.Select(d => (double?)d.DurationMinutes).ToList()
            : new List<double?> { 0, 0, 0, 0, 0, 0, 0 };

        var colors = data.Select(d => d > 0 ? "#dc3545" : "#e9ecef").ToList();

        var datasets = new List<IChartDataset>
        {
            new BarChartDataset
            {
                Data = data,
                BackgroundColor = colors,
                BorderWidth = new List<double> { 0 }
            }
        };

        var options = new BarChartOptions
        {
            Plugins = new BarChartPlugins { Legend = new ChartPluginsLegend { Display = false } },
            Scales = new()
            {
                X = new() { Grid = new() { Display = false } },
                Y = new() { Ticks = new() { Display = false } }
            }
        };

        await _barChart.InitializeAsync(new ChartData { Labels = labels, Datasets = datasets }, options);
    }
}