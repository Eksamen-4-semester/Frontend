@using BlazorBootstrap

<LineChart @ref="_lineChart" Width="100" Height="300" />

@code {
    private LineChart _lineChart = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await RenderChartAsync();
    }

    private async Task RenderChartAsync()
    {
        var labels = new List<string> { "Jan", "Feb", "Mar", "Apr", "Maj", "Jun", "Jul", "Aug", "Sep", "Okt" };
        var datasets = new List<IChartDataset>
        {
            new LineChartDataset
            {
                Label = "Skridt",
                Data = new List<double?> { 4000, 4500, 4200, 6000, 5800, 7000, 9178, 8500, 8000, 9000 },
                BackgroundColor = "rgba(220, 53, 69, 0.2)", // Rødlig gennemsigtig
                BorderColor = "rgb(220, 53, 69)",         // Rød linje
                Fill = true,                              // Gør det til en Area chart
                PointBackgroundColor = new List<string> {"rgb(220, 53, 69)"},
                Tension = 0.4                             // Gør linjen blød/buet
            }
        };

        var options = new LineChartOptions
        {
            Plugins = new LineChartPlugins { Legend = new ChartPluginsLegend { Display = false } },
            Scales = new()
            {
                X = new()
                {
                    Grid = new() { Display = false }
                },
                Y = new()
                {
                    Grid = new() { Color = "rgba(255,255,255,0.1)" }
                }
            }
        };

        await _lineChart.InitializeAsync(new ChartData { Labels = labels, Datasets = datasets }, options);
    }
};