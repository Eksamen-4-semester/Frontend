@using BlazorBootstrap
@using Frontend.Models.Analytics
@using Frontend.Services

<LineChart @ref="_lineChart" Width="100" Height="300" />

@code {
    [Parameter] public List<WeeklySessionDto> Last7Days { get; set; } = new();

    private LineChart _lineChart = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await RenderChartAsync();
    }

    private async Task RenderChartAsync()
    {
        var labels = Last7Days.Any()
            ? Last7Days.Select(d => d.Day).ToList()
            : new List<string> { "Man", "Tir", "Ons", "Tor", "Fre", "Lør", "Søn" };

        var data = Last7Days.Any()
            ? Last7Days.Select(d => (double?)d.DurationMinutes).ToList()
            : new List<double?> { 0, 0, 0, 0, 0, 0, 0 };

        var datasets = new List<IChartDataset>
        {
            new LineChartDataset
            {
                Label = "Træningstid (min)",
                Data = data,
                BackgroundColor = "rgba(220, 53, 69, 0.2)",
                BorderColor = "rgb(220, 53, 69)",
                Fill = true,
                PointBackgroundColor = new List<string> { "rgb(220, 53, 69)" },
                Tension = 0.4
            }
        };

        var options = new LineChartOptions
        {
            Plugins = new LineChartPlugins { Legend = new ChartPluginsLegend { Display = false } },
            Scales = new()
            {
                X = new() { Grid = new() { Display = false } },
                Y = new() { Grid = new() { Color = "rgba(255,255,255,0.1)" } }
            }
        };

        await _lineChart.InitializeAsync(new ChartData { Labels = labels, Datasets = datasets }, options);
    }
}